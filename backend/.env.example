# Cadena de conexión a PostgreSQL (SQLAlchemy async / asyncpg)
DATABASE_URL=postgresql+asyncpg://reserva_app:elegi-una-password@localhost:5432/reserva_vehiculos

# Credenciales de administrador (HTTP Basic) — RF-14
# Generar el hash con: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('tu-password'))"
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# Zona horaria fija de la empresa (ver research.md §5)
APP_TIMEZONE=America/Argentina/Buenos_Aires

# Origen exacto del frontend, para restringir CORS (Agents.md §Backend)
FRONTEND_ORIGIN=http://localhost:5173
